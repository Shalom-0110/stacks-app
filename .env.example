# =============================================================
# Stacks — personal dev environment
# Copy to `.env` and fill in the blanks. Everything here is
# either free-tier or optional for local development.
# =============================================================

# Django core
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
EXP_DJANGO_SECRET_KEY=change-me
EXP_DEBUG=True
EXP_ALLOWED_HOSTS=localhost,127.0.0.1
EXP_BASE_URL=http://localhost:8000
EXP_FQDN=localhost

# Database
# Leave ALL of these blank to use SQLite (zero setup, works out of the box).
# Fill them in only if you want Postgres.
EXP_POSTGRES_HOST=
EXP_POSTGRES_DATABASE=stacks
EXP_POSTGRES_USER=stacks
EXP_POSTGRES_PASSWORD=
EXP_POSTGRES_PORT=5432

# Google OAuth (optional)
# Only needed for "Sign in with Google". Leave blank to use
# username/password login. Get credentials free at console.cloud.google.com.
EXP_GOOGLE_OAUTH_CLIENT_ID=
EXP_GOOGLE_OAUTH_CLIENT_SECRET=
